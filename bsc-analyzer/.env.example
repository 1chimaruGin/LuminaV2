# Copy to .env and fill in locally — never commit real secrets.

# BSC HTTP RPC (required for lumina_kol_monitor / replay)
QUICK_NODE_BSC_RPC=

# Optional fallback
ALCHEMY_BSC_RPC=

# GMGN OpenAPI — required for canonical dataset builds (scripts/build_kol_dataset.py).
# Default behavior loads this file and calls GMGN unless you pass --no-gmgn.
# Rotate the key in the GMGN dashboard if it was ever exposed.
GMGN_API_KEY=
GMGN_API_BASE=https://gmgn.ai/api
