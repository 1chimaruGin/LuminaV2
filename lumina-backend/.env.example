# Lumina Backend Environment Variables
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://lumina:lumina@localhost:5432/lumina

# Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=30

# Exchange API Keys (optional — public endpoints work without keys)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# Grok API (for AI wallet analysis)
GROK_API_KEY=
GROK_API_URL=https://api.x.ai/v1

# App
DEBUG=true
